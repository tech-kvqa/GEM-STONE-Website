# ── Crystal Luxe — Backend Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values

# Database (default: SQLite for development)
DATABASE_URL=sqlite:///./crystal_luxe.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost:5432/crystal_luxe

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=crystal-luxe-super-secret-key-change-me-in-production

# Razorpay Payment Gateway (optional — enables online payments)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Email (optional — enables order confirmation emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password

# App
DEBUG=True
